---
import BaseLayout from "./BaseLayout.astro";
import ArticleToc from "../components/ArticleToc.astro";
import { formatDate } from "../lib/content";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date?: Date;
  tags?: string[];
  eyebrow?: string;
  image?: string;
  backHref: string;
  backLabel: string;
  headings?: Heading[];
}

const { title, description, date, tags = [], eyebrow, image, backHref, backLabel, headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={title} description={description} image={image} article>
  <article class:list={{ "article-shell": true, "with-toc": tocHeadings.length > 0 }}>
    <header class="article-header">
      <a class="back-link" href={backHref}>← {backLabel}</a>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="article-dek">{description}</p>
      {
        (date || tags.length > 0) && (
          <div class="article-meta">
            {date && <time datetime={date.toISOString()}>{formatDate(date)}</time>}
            {tags.map((tag) => (
              <a href={`/blog/tag/${encodeURIComponent(tag)}/`}>#{tag}</a>
            ))}
          </div>
        )
      }
    </header>
    <div class="article-body">
      <div class="prose"><slot /></div>
      {tocHeadings.length > 0 && <ArticleToc headings={tocHeadings} />}
    </div>
    <slot name="after" />
  </article>
</BaseLayout>
