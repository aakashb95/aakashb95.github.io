---
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "../lib/content";

interface Props {
  title: string;
  description: string;
  date?: Date;
  tags?: string[];
  eyebrow?: string;
  image?: string;
  backHref: string;
  backLabel: string;
}

const { title, description, date, tags = [], eyebrow, image, backHref, backLabel } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} article>
  <article class="article-shell">
    <header class="article-header">
      <a class="back-link" href={backHref}>← {backLabel}</a>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="article-dek">{description}</p>
      {
        (date || tags.length > 0) && (
          <div class="article-meta">
            {date && <time datetime={date.toISOString()}>{formatDate(date)}</time>}
            {tags.map((tag) => (
              <span>{tag}</span>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose"><slot /></div>
  </article>
</BaseLayout>
