---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, postUrl } from "../../lib/content";
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Writing" description="Thoughts, learnings, and field notes by Aakash Bakhle.">
  <header class="page-header">
    <p class="eyebrow">Writing index / {String(posts.length).padStart(2, "0")}</p><h1>Thoughts, learnings, rants.</h1><p
      class="page-intro"
    >
      Notes written to clarify what I think—usually about building software, evaluating AI, and learning in public.
    </p>
  </header>
  <div class="writing-list" style="margin-bottom: 8rem">
    {
      posts.map((post) => (
        <a class="writing-row" href={postUrl(post)}>
          <>
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            <h3>{post.data.title}</h3>
            <span class="row-arrow">↗</span>
          </>
        </a>
      ))
    }
  </div>
</BaseLayout>
