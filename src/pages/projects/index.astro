---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assetUrl, projectUrl } from "../../lib/content";
const projects = (await getCollection("projects")).sort((a, b) => a.data.importance - b.data.importance);
---

<BaseLayout title="projects" description="Whatever I make and find useful, it will be here.">
  <header class="page-header">
    <h1>projects</h1>
    <p>Whatever I make and find useful, it will be here.</p>
  </header>
  <div class="projects-grid">
    {
      projects.map((project) => (
        <a class="project-card" href={projectUrl(project)}>
          <img class="project-card-image" src={assetUrl(project.data.img)} alt="" loading="lazy" />
          <div class="project-card-copy">
            <h2>{project.data.title}</h2>
            <p>{project.data.description}</p>
            {project.data.status === "decommissioned" && <small class="project-status">decommissioned</small>}
          </div>
        </a>
      ))
    }
  </div>
</BaseLayout>
