---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const usesPage = (await getCollection("pages")).find((page) => page.id === "uses");
if (!usesPage) throw new Error("Missing Uses page content");
const { Content } = await render(usesPage);
---

<BaseLayout title={usesPage.data.title} description={usesPage.data.description}>
  <header class="page-header">
    <h1>{usesPage.data.title}</h1>
  </header>
  <section class="uses-copy">
    <Content />
  </section>
</BaseLayout>
