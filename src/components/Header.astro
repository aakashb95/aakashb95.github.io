---
const currentPath = Astro.url.pathname;
const links = [
  { href: "/blog/", label: "blog" },
  { href: "/projects/", label: "projects" },
  { href: "/uses/", label: "uses" },
];
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label="Aakash Bakhle, home"> Aakash Bakhle </a>
  <nav aria-label="Primary navigation">
    {
      links.map((link) => (
        <a href={link.href} aria-current={currentPath.startsWith(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))
    }
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme">
      <span class="theme-icon" aria-hidden="true">
        <svg class="theme-icon-moon" viewBox="0 0 24 24">
          <path d="M20 15.2A8.5 8.5 0 0 1 8.8 4a8.5 8.5 0 1 0 11.2 11.2Z"></path>
        </svg>
        <svg class="theme-icon-sun" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="3.5"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
      </span>
    </button>
  </nav>
</header>

<script>
  const root = document.documentElement;
  const toggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const themeColor = document.querySelector<HTMLMetaElement>("meta[name='theme-color']");

  const currentTheme = () =>
    root.dataset.theme ?? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");

  const syncToggle = () => {
    const theme = currentTheme();
    if (toggle) {
      const nextTheme = theme === "dark" ? "light" : "dark";
      toggle.dataset.theme = theme;
      toggle.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
      toggle.title = `Switch to ${nextTheme} mode`;
    }
    if (themeColor) themeColor.content = theme === "dark" ? "#111111" : "#ffffff";
  };

  syncToggle();

  toggle?.addEventListener("click", () => {
    const theme = currentTheme() === "dark" ? "light" : "dark";
    root.dataset.theme = theme;
    localStorage.setItem("theme", theme);
    syncToggle();
  });
</script>
