---
const currentPath = Astro.url.pathname;
const links = [
  { href: "/projects/", label: "Projects" },
  { href: "/blog/", label: "Writing" },
  { href: "/uses/", label: "Uses" },
];
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label="Aakash Bakhle, home">
    <span class="wordmark-mark">AB</span>
    <span class="wordmark-name">Aakash Bakhle</span>
  </a>
  <nav aria-label="Primary navigation">
    {
      links.map((link) => (
        <a href={link.href} aria-current={currentPath.startsWith(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
