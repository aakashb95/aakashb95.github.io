---
const currentPath = Astro.url.pathname;
const links = [
  { href: "/blog/", label: "blog" },
  { href: "/projects/", label: "projects" },
  { href: "/uses/", label: "uses" },
];
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label="Aakash Bakhle, home"> Aakash Bakhle </a>
  <nav aria-label="Primary navigation">
    {
      links.map((link) => (
        <a href={link.href} aria-current={currentPath.startsWith(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
