---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, postUrl } from "../lib/content";

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  posts: CollectionEntry<"blog">[];
}
const { title, eyebrow, description, posts } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="page-header">
    <p class="eyebrow">{eyebrow} / {String(posts.length).padStart(2, "0")}</p><h1>{title}</h1><p class="page-intro">
      {description}
    </p>
  </header>
  <div class="writing-list" style="margin-bottom: 8rem">
    {
      posts.map((post) => (
        <a class="writing-row" href={postUrl(post)}>
          <>
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            <h3>{post.data.title}</h3>
            <span class="row-arrow">↗</span>
          </>
        </a>
      ))
    }
  </div>
</BaseLayout>
