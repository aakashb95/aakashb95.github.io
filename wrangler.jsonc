{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aakashb-portfolio",
  "compatibility_date": "2026-07-10",
  "routes": [
    {
      "pattern": "aakashb.xyz/*",
      "zone_name": "aakashb.xyz",
    },
    {
      "pattern": "www.aakashb.xyz/*",
      "zone_name": "aakashb.xyz",
    },
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
}
